<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Book Notes | Sripath Cherukuri</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@4.0.0/dist/css/bootstrap.min.css" integrity="sha384-Gn5384xqQ1aoWXA+058RXPxPg6fy4IWvTNh0E263XmFcJlSAwiGgFAW/dAiS6JXm" crossorigin="anonymous">
    <link rel="icon" type="image/x-icon" href="/images/favicon.ico">

    <style>
        body {
            font-family: Arial, sans-serif;
            background-color: #EFE9F4;
            margin: 0;
            padding: 0;
            display: flex;
            justify-content: center;
        }

        .container {
            width: 60%;
            background-color: #57A773;
            padding: 2em;
            margin-top: 2em;
            color: #EFE9F4;
            border-radius: 10px;
        }

        .book-item {
            display: flex;
            margin-bottom: 2em;
            border-bottom: 1px solid #ddd;
            padding-bottom: 1em;
        }

        .book-thumbnail {
            flex: 0 0 150px;
            margin-right: 1em;
        }

        .book-thumbnail img {
            max-width: 100%;
            border-radius: 5px;
        }

        .book-details {
            flex: 1;
        }

        .book-details h2 {
            font-size: 1.5em;
            margin: 0 0 0.5em;
            color: #EFE9F4;
        }

        .book-details p {
            margin: 0.5em 0;
            color: #EFE9F4;
        }

        .book-details .links {
            margin-top: 0.5em;
        }

        .book-details .links a {
            color: #3498db;
            text-decoration: none;
            margin-right: 1em;
        }

        hr { 
            display: flex;
            border: 5px solid #ddd;
        }

        a:link, a:visited {
            background-color: #EFE9F4;
            color: black;
            padding: 14px 25px;
            text-align: center;
            text-decoration: none;
            display: inline-block;
            border-radius: 10px;
        }

        a:hover, a:active {
            background-color: black;
            color: white;
        }
    </style>
</head>
<body>
    <div class="container">
        <h1>SRIPATH CHERUKURI</h1>
        <h2>BOOKS I'VE READ</h2>
        <h4><p>Tiny summary but detailed notes for each. Use the ISBN number to find it from your local library or anywhere else. 
            This page will constantly update as I read more, so bookmark it if you want to check back in a few months.</p>
            
            <p>Sorted with my top recommendations up top. Sort by title, newest, or best.</p>
            
            <p>And please read this FAQ page about these notes, if you have any questions. You can also email me.</p>
            
            </h4>
            <br>
            <a href="/new" class="btn btn-light">Add new</a>
            <hr>
            <br>
    
        <% books.forEach(book => { %>
            <div class="book-item">
                <div class="book-thumbnail">
                    <img src="<%= book.cover_url %>" alt="Cover of <%= book.title %>">
                </div>
                <div class="book-details">
                    <h2><%= book.title %> - by <%= book.author %></h2>
                    <p><strong>Date read:</strong> <%= book.date_read %></p>
                    <p><strong>How strongly I recommend it:</strong> <%= book.rating %>/10</p>
                    <p><%= book.review %></p>
                    <div class="links">
                        <a href="#">Read my notes</a> 
                        <a href="<%= book.amazon_url %>">Amazon page</a>
                    </div>
                </div>
            </div>
        <% }); %>
    </div>
</body>
</html>
